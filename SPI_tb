//////////////////////////////////////////////////////////////////////////////////
// Testbench for SPI communication
// This testbench drives the SPI_Top module and verifies
// full duplex communication between SPI master and slave.
//////////////////////////////////////////////////////////////////////////////////

module SPI_tb;

// ------------------------------------------------------------------
// Testbench input signals (driven by the testbench)
// ------------------------------------------------------------------
reg clk;            // System clock
reg rst;            // Reset signal
reg tx_enable;      // Signal used to start SPI transfer

reg [7:0] master_tx; // Data that master will transmit
reg [7:0] slave_tx;  // Data that slave will transmit


// ------------------------------------------------------------------
// Output signals from the DUT
// ------------------------------------------------------------------
wire [7:0] slave_rx;   // Data received by slave from master
wire [7:0] master_rx;  // Data received by master from slave
wire done;             // Indicates SPI transfer completion


// ------------------------------------------------------------------
// DUT Instantiation
// Connecting SPI_Top module with testbench signals
// ------------------------------------------------------------------
SPI_Top DUT(

    .clk(clk),            // System clock
    .rst(rst),            // Reset signal
    .tx_enable(tx_enable),// Start SPI transfer

    .master_tx(master_tx),// Data sent by master
    .slave_tx(slave_tx),  // Data sent by slave

    .slave_rx(slave_rx),  // Data received by slave
    .master_rx(master_rx),// Data received by master
    .done(done)           // Transfer completion flag
);


// ------------------------------------------------------------------
// Clock generation
// Creates a 100 MHz clock (10 ns period)
// ------------------------------------------------------------------
always #5 clk = ~clk;


// ------------------------------------------------------------------
// Stimulus block
// Initializes signals and starts SPI transaction
// ------------------------------------------------------------------
initial
begin

clk = 0;           // Initialize clock
rst = 1;           // Apply reset
tx_enable = 0;     // Disable SPI transfer initially

// Data to be exchanged between master and slave
master_tx = 8'h49; // Master will send FE
slave_tx  = 8'hA5; // Slave will send A5

#40
rst = 0;           // Release reset

#20
tx_enable = 1;     // Start SPI communication

#10
tx_enable = 0;     // Disable start signal

end


// ------------------------------------------------------------------
// Display results once transfer completes
// ------------------------------------------------------------------
always @(posedge done)
begin

$display("------------------------------------------------");
$display("SPI Transfer Completed");
$display("Master Transmitted = %h", master_tx);
$monitor("Slave received  = %h", slave_rx);
$display("Slave Transmitted  = %h", slave_tx);


$monitor("Master received = %h", master_rx);
$display("------------------------------------------------");

end


// ------------------------------------------------------------------
// End simulation after fixed time
// ------------------------------------------------------------------
initial
begin
#2000
$finish;
end

endmodule
